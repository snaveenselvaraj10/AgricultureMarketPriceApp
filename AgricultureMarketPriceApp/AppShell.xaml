<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AgricultureMarketPriceApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AgricultureMarketPriceApp"
    xmlns:pages="clr-namespace:AgricultureMarketPriceApp.Pages"
    Title="AgricultureMarketPriceApp">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="MonthlyGraph"
        ContentTemplate="{DataTemplate pages:MonthlyGraphPage}"
        Route="monthlygraph" />

</Shell>
