<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:AgricultureMarketPriceApp.Pages"
             xmlns:models="clr-namespace:AgricultureMarketPriceApp.Models"
             x:Class="AgricultureMarketPriceApp.MainPage"
             Title="Daily Prices">

    <Grid RowDefinitions="Auto, Auto, *" Padding="0">
        <!-- Header -->
        <Grid Row="0" BackgroundColor="#12A85A" HeightRequest="120" Padding="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Source="dotnet_bot.png" HeightRequest="40" WidthRequest="40" VerticalOptions="Center" />
            <StackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Text="Market Prices" FontAttributes="Bold" TextColor="White" FontSize="20" />
                <Label Text="Daily updated agricultural prices" TextColor="White" FontSize="12" />
            </StackLayout>

            <StackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                <Label Text="Today" TextColor="White" HorizontalOptions="End" />
                <Label Text="Dec 21, 2024" TextColor="White" FontSize="12" HorizontalOptions="End" />
            </StackLayout>
        </Grid>

        <!-- Filters row: pickers and apply button, plus a diagnostics label for debugging API requests -->
        <StackLayout Grid.Row="1" Orientation="Vertical" Padding="12" Spacing="8">
            <StackLayout Orientation="Horizontal" Spacing="8">
                <Picker x:Name="StatePicker" Title="State" WidthRequest="140" />
                <Picker x:Name="DistrictPicker" Title="District" WidthRequest="140" />
                <Picker x:Name="CommodityPicker" Title="Commodity" WidthRequest="140" />
                <Button Text="Apply" Clicked="OnApplyFiltersClicked" />
            </StackLayout>
            <Label x:Name="DiagnosticsLabel" FontSize="12" TextColor="#666" LineBreakMode="TailTruncation" />
        </StackLayout>

        <CollectionView x:Name="PricesCollection" Grid.Row="2" Margin="12" SelectionMode="Single" ItemsLayout="VerticalList">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CommoditySummary">
                    <Frame BackgroundColor="White" CornerRadius="12" Padding="12" Margin="8,6" HasShadow="False" BorderColor="#E1E1E1">
                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto">
                            <Image Source="{Binding Icon}" WidthRequest="48" HeightRequest="48" />

                            <StackLayout Grid.Column="1" Padding="8,0">
                                <Label Text="{Binding Commodity}" FontAttributes="Bold" />
                                <Label Text="{Binding AverageModalPrice, StringFormat='₹{0:N0}'}" FontSize="14" TextColor="{StaticResource Gray600}" />
                            </StackLayout>

                            <StackLayout Grid.Column="2" VerticalOptions="Center">
                                <Frame BackgroundColor="{Binding PercentChange, Converter={StaticResource PercentToBrushConverter}}" CornerRadius="6" Padding="6,4" HasShadow="False" BorderColor="Transparent">
                                    <Label Text="{Binding PercentChange, StringFormat='{0:+0.0%;-0.0%}'}" TextColor="#0DAF6A" FontSize="12" />
                                </Frame>
                            </StackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
