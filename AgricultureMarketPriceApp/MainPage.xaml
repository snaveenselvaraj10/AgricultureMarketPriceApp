<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:AgricultureMarketPriceApp.Pages"
             x:Class="AgricultureMarketPriceApp.MainPage"
             Title="Daily Prices">

    <VerticalStackLayout Padding="12">
        <HorizontalStackLayout Padding="0,8" Spacing="8">
            <Entry x:Name="ApiKeyEntry" Placeholder="Enter API Key" HorizontalOptions="FillAndExpand" />
            <Button Text="Save Key" Clicked="OnSaveApiKeyClicked" />
        </HorizontalStackLayout>
        <Label x:Name="ApiKeyStatusLabel" FontSize="Small" TextColor="Gray" />

        <HorizontalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Padding="0,8">
            <Label Text="Daily Market Prices" FontAttributes="Bold" HorizontalOptions="StartAndExpand" />
            <Button Text="Monthly Graph" Clicked="OnMonthlyGraphClicked" />
        </HorizontalStackLayout>

        <CollectionView x:Name="PricesCollection" SelectionMode="Single" ItemsLayout="VerticalList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 6">
                        <Grid Padding="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Label Text="{Binding Commodity}" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="{Binding Market}" FontSize="Small" />
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Modal_price, StringFormat='₹{0:N0}'}" HorizontalOptions="End" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>

</ContentPage>
