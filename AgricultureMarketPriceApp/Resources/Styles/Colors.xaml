<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <Color x:Key="Primary">#512BD4</Color>
  <Color x:Key="MarketGreen">#0DAF6A</Color>
  <Color x:Key="MarketGreenLight">#E9F9F0</Color>
  <Color x:Key="MarketHeaderGreen">#12A85A</Color>
  <Color x:Key="DangerRed">#FF6B6B</Color>

  <Color x:Key="White">#FFFFFF</Color>
  <Color x:Key="Gray600">#404040</Color>
  <Color x:Key="Gray100">#E1E1E1</Color>

  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
  <SolidColorBrush x:Key="MarketGreenBrush" Color="{StaticResource MarketGreen}" />
  <SolidColorBrush x:Key="MarketGreenLightBrush" Color="{StaticResource MarketGreenLight}" />
  <SolidColorBrush x:Key="MarketHeaderGreenBrush" Color="{StaticResource MarketHeaderGreen}" />
  <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRed}" />

</ResourceDictionary>
