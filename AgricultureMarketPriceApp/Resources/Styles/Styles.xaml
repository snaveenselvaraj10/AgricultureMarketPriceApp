<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <Style x:Key="MarketHeader" TargetType="Grid">
    <Setter Property="BackgroundColor" Value="{StaticResource MarketHeaderGreen}" />
    <Setter Property="HeightRequest" Value="120" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style x:Key="MarketCard" TargetType="Frame">
    <Setter Property="BackgroundColor" Value="{StaticResource White}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="Margin" Value="8,6" />
    <Setter Property="BorderColor" Value="{StaticResource Gray100}" />
  </Style>

  <Style x:Key="BadgePositive" TargetType="Frame">
    <Setter Property="BackgroundColor" Value="{StaticResource MarketGreenLight}" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="6,4" />
  </Style>

</ResourceDictionary>
